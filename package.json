{
  "name": "sonikoma",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run start",
    "start": "node scripts/run-frontend.js",
    "frontend:dev": "npm run frontend",
    "backend": "node scripts/run-backend.js",
    "python": "npm run backend",
    "python:prod": "cd backend/app && cross-env NODE_ENV=production ..\\..\\.venv\\Scripts\\python.exe main.py",
    "frontend": "node scripts/run-frontend.js --only-frontend",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build": "npm run build:frontend",
    "preview": "cd frontend && npm run preview",
    "typecheck": "cd frontend && npm run typecheck",
    "test": "echo \"No tests specified\" && exit 0",
    "format": "prettier --write .",
    "start:prod": "npm run python:prod",
    "start:server": "npm run start:prod",
    "install:python": ".venv\\Scripts\\python.exe -m pip install -r backend/requirements.txt",
    "clean": "rimraf frontend/dist",
    "docker:build": "docker build -t sonikoma .",
    "docker:run": "docker run -p 3000:3000 sonikoma",
    "lint": "cd frontend && npm run lint"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "prettier": "^2.8.8",
    "rimraf": "^5.0.1",
    "tsx": "^4.21.0"
  }
}

{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://sonikoma.up.railway.app/api/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "https://sonikoma.up.railway.app/media/$1"
    },
    {
      "source": "/videos/(.*)",
      "destination": "https://sonikoma.up.railway.app/videos/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
